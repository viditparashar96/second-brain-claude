{
  "description": "Second Brain lifecycle hooks — memory injection, context persistence, security guardrails",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/session_start.py\"",
            "timeout": 10000,
            "statusMessage": "Loading Second Brain memory..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/pre_compact.py\"",
            "timeout": 15000,
            "statusMessage": "Saving context before compaction..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/session_end.py\"",
            "timeout": 15000,
            "statusMessage": "Saving session context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/guardrails.py\"",
            "timeout": 5000,
            "statusMessage": "Checking security guardrails..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Review what just happened in this conversation turn. If there were any decisions made, action items assigned, important facts learned, project updates, or meeting outcomes — log them to the daily vault file at ~/.second-brain/vault/daily/ using the format: '- **HH:MM** — <what happened>'. Only log genuinely important items, not routine exchanges. If nothing noteworthy happened, do nothing. Do NOT mention this check to the user.",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
